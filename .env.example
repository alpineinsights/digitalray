# Copy to ".env" and fill in your real credentials
# NEVER commit the real .env to git

DIGITALRAY_EMAIL=your-email@example.com
DIGITALRAY_PASSWORD=your-password-here

# Optional: a secret key that your calling chatbot must send in the X-API-Key header
# Leave empty to disable auth (not recommended in production)
API_SECRET_KEY=

# Optional port (Railway overrides this automatically)
PORT=8000
